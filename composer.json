{
    "name": "ultradev/paghiperpix-openmage",
    "description": "Pix dinâmico via PagHiper (API pix.paghiper.com) para OpenMage 20.x / PHP 8.1+, sem boleto acoplado",
    "type": "magento-module",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "UltraDev",
            "email": "contato@ultradev.com.br",
            "homepage": "https://ultradev.com.br"
        }
    ],
    "require": {
        "php": ">=8.1",
        "magento-hackathon/magento-composer-installer": "*"
    },
    "extra": {
        "magento-root-dir": "../../",
        "magento-deploystrategy": "copy",
        "auto-append-gitignore": true
    },
    "keywords": ["openmage", "magento", "paghiper", "pix", "qrcode", "ultradev"]
