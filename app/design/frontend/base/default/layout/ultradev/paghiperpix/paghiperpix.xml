<?xml version="1.0"?>
<layout version="0.1.0">
    <checkout_onepage_success translate="label">
        <reference name="head">
            <action method="addCss">
                <stylesheet>ultradev/paghiperpix/css/paghiperpix.css</stylesheet>
            </action>
            <action method="addItem">
                <type>skin_js</type>
                <name>ultradev/paghiperpix/js/main.js</name>
            </action>
        </reference>
        <reference name="content">
            <reference name="checkout.success">
                <block type="core/template" name="ultradev.paghiperpix.success" template="ultradev/paghiperpix/checkout/success.phtml" />
            </reference>
        </reference>
    </checkout_onepage_success>
</layout>
